# Shopify Storefront API Configuration
# Copy this file to .env and fill in your actual values

# Your Shopify store domain (e.g., your-store.myshopify.com)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token
# Get this from your Shopify Admin > Settings > Apps and sales channels > Develop apps
VITE_SHOPIFY_STOREFRONT_API_TOKEN=your_storefront_api_token

# Shopify API version (default: 2024-01)
VITE_SHOPIFY_API_VERSION=2024-01

# Optional: Custom Banners (JSON format)
# Example: [{"id":"1","title":"Sale","subtitle":"50% OFF","image":"https://...","link":"/category/sale","position":"hero"}]
# VITE_CUSTOM_BANNERS=[{"id":"1","title":"Summer Sale","subtitle":"Up to 50% OFF","image":"https://your-image-url.com/banner1.jpg","link":"/category/sale","position":"hero"}]
